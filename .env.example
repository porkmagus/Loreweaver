# Environment variables for Loreweaver development
# Copy to .env and adjust values as needed

# Database
POSTGRES_USER=loreweaver
POSTGRES_PASSWORD=loreweaver
POSTGRES_DB=loreweaver
DATABASE_URL=postgresql://loreweaver:loreweaver@postgres:5432/loreweaver

# Qdrant
QDRANT_URL=http://qdrant:6333

# API
API_PORT=3001
API_HOST=0.0.0.0
NODE_ENV=development

# Frontend
WEB_PORT=5173
VITE_API_URL=http://localhost:3001

# AI (configure as needed)
OPENAI_API_KEY=
