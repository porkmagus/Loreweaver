# Environment variables for Loreweaver development
# Copy to .env and adjust values as needed

# Database
POSTGRES_USER=loreweaver
POSTGRES_PASSWORD=loreweaver
POSTGRES_DB=loreweaver
DATABASE_URL=postgresql://loreweaver:loreweaver@postgres:5432/loreweaver

# Qdrant
QDRANT_URL=http://qdrant:6333

# API
API_PORT=3001
API_HOST=0.0.0.0
NODE_ENV=development

# Frontend
WEB_PORT=5173
VITE_API_URL=http://localhost:3001

# AI — optional. Without a key, chat uses simulated responses.
OPENAI_API_KEY=
CHAT_MODEL=gpt-4o-mini

# Provider flexibility
AI_PROVIDER=custom-openai
AI_BASE_URL=http://localhost:1234/v1
AI_API_KEY=
AI_CHAT_MODEL=
AI_EMBEDDING_MODEL=
AI_IMAGE_MODEL=
AI_TEMPERATURE=0.8
AI_MAX_TOKENS=800

OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=

# Images — optional. Uses OPENAI_API_KEY when enabled; deterministic fallbacks are used otherwise.
IMAGE_GENERATION_ENABLED=true
IMAGE_MODEL=gpt-image-1-mini
IMAGE_QUALITY=low
IMAGE_GENERATION_TIMEOUT_MS=20000

# Embeddings
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536
QDRANT_COLLECTION=lore_chunks
