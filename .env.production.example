# Production environment variables for Loreweaver
# Copy to .env.production and adjust values for your deployment

# Database (update host, user, password for your environment)
POSTGRES_USER=loreweaver
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=loreweaver
DATABASE_URL=postgresql://loreweaver:change-me-in-production@postgres:5432/loreweaver

# Qdrant
QDRANT_URL=http://qdrant:6333

# API
API_PORT=3001
API_HOST=0.0.0.0
NODE_ENV=production

# Frontend
WEB_PORT=5173
VITE_API_URL=http://localhost:3001

# AI (required)
OPENAI_API_KEY=sk-...
CHAT_MODEL=gpt-4o-mini

# Images
IMAGE_GENERATION_ENABLED=true
IMAGE_MODEL=gpt-image-1-mini
IMAGE_QUALITY=low
IMAGE_GENERATION_TIMEOUT_MS=20000

# Embeddings
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536
QDRANT_COLLECTION=lore_chunks
