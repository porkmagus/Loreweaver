{
  "name": "@loreweaver/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx src/seed/index.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@loreweaver/shared": "0.0.1",
    "@qdrant/js-client-rest": "^1.18.0",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.5",
    "openai": "^6.37.0",
    "pg": "^8.20.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "drizzle-kit": "^0.31.10",
    "supertest": "^7.2.2",
    "tsx": "^4.11.0",
    "typescript": "^5.4.5",
    "vitest": "^4.1.6"
  }
}
